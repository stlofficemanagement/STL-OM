rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for validating structures
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation for branches
    function isValidBranch(data) {
      return data.id is string
        && data.name is string
        && data.name.size() > 0;
    }

    // Validation for audit logs
    function isValidLog(data) {
      return data.id is string
        && data.dateTime is string
        && data.user is string
        && data.action is string;
    }

    // Validation for sessions
    function isValidSession(data) {
      return data.id is string
        && data.name is string
        && data.createdDate is string;
    }

    // Validation for files
    function isValidFileMetadata(data) {
      return data.id is string
        && data.fileName is string
        && data.fileType is string
        && data.totalChunks is number
        && data.totalSize is number
        && data.uploadedAt is string;
    }

    // Validation for file chunks
    function isValidFileChunk(data) {
      return data.fileId is string
        && data.index is number
        && data.data is string;
    }

    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Branches collection rules
    match /branches/{branchId} {
      allow read: if true;
      allow create, update: if isValidId(branchId) && isValidBranch(incoming());
      allow delete: if isValidId(branchId);
    }

    // Logs collection rules
    match /logs/{logId} {
      allow read: if true;
      allow create, update: if isValidId(logId) && isValidLog(incoming());
      allow delete: if isValidId(logId);
    }

    // Sessions collection rules
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if isValidId(sessionId) && isValidSession(incoming());
      allow delete: if isValidId(sessionId);
    }

    // Files metadata collection rules
    match /files/{fileId} {
      allow read: if true;
      allow create, update: if isValidId(fileId) && isValidFileMetadata(incoming());
      allow delete: if isValidId(fileId);
    }

    // File chunks collection rules
    match /fileChunks/{chunkId} {
      allow read: if true;
      allow create, update: if isValidId(chunkId) && isValidFileChunk(incoming());
      allow delete: if isValidId(chunkId);
    }
  }
}
